{
    "version": "2.2.0",
    "description": "Clean, tune and optimize your Registry",
    "homepage": "https://www.revouninstaller.com/products/revo-registry-cleaner-pro/",
    "license": "Shareware",
    "url": "https://revoregcleaner.b-cdn.net/rrc220/RRC_ProPortable.zip",
    "hash": "59073dd667bbeaa11216848b8ac7aeedf9a05f4740657c8f468c0f6a5001cb07",
    "extract_dir": "Revo Registry Cleaner Portable",
    "shortcuts": [
        [
            "Revo Registry Cleaner.exe",
            "Revo Registry Cleaner"
        ]
    ],
    "persist": [
        "Data",
        "license.dat",
        "settings.dat"
    ],
    "checkver": {
        "script": [
            "$base_url = 'https://www.revouninstaller.com/revo-registry-cleaner-pro-version-history/'",
            "$page = Invoke-WebRequest $base_url -UseBasicParsing",
            "$dl_page = $page.Links.Where({ $_ -match 'RRC_ProPortable.zip' }, 1) | Select-Object -ExpandProperty outerHTML",
            "$dl_page"
        ],
        "regex": "href=\"https://(?<path>.*?)/RRC_ProPortable.zip\".+PORTABLE\\s([\\d.]+)\\s"
    },
    "autoupdate": {
        "url": "https://$matchPath/RRC_ProPortable.zip"
    }
}
